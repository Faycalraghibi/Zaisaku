# ──────────────────────────────────────────────
# Zaisaku — Environment Configuration
# ──────────────────────────────────────────────

# Environment: "dev" = Ollama (local) | "prod" = OpenRouter (cloud)
ENV=dev

# ── Ollama (dev) ─────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b

# ── OpenRouter (prod) ────────────────────────
OPENROUTER_API_KEY=sk-or-change-me
OPENROUTER_MODEL=google/gemini-flash-1.5

# ── ChromaDB ─────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=zaisaku_docs

# ── Embeddings ───────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Chunking ─────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval ────────────────────────────────
RETRIEVAL_TOP_K=10
RERANK_TOP_K=3

# ── FastAPI ──────────────────────────────────
APP_PORT=5000
SECRET_KEY=change-me-in-production
CORS_ORIGIN=http://localhost:5173
